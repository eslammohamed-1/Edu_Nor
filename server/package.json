{
  "name": "edunor-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docs:export": "tsx scripts/export-openapi.ts",
    "migrate:quizzes": "tsx ../scripts/migrate-quizzes-snapshot.ts",
    "migrate:sqlite": "tsx ../scripts/migrate-sqlite-to-postgres.ts",
    "gen:api": "openapi-typescript ./openapi.json -o ../app/src/types/api.ts",
    "bucket:ensure": "tsx scripts/ensure-s3-bucket.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^11.10.0",
    "openapi-typescript": "^7.10.1",
    "prisma": "^6.19.0",
    "prisma-mock": "^1.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
