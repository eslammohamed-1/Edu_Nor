generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  admin
  teacher
  super_admin
}

model User {
  id              String  @id @default(cuid())
  email           String  @unique
  passwordHash    String
  name            String
  role            Role    @default(student)
  banned          Boolean @default(false)
  grade           String?
  phone           String?
  stage           String?
  secondaryTrack  String?
  permissionsJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens         RefreshToken[]
  quizAttempts          QuizAttempt[]
  lessonProgress        LessonProgress[]
  certificates          Certificate[]
  passwordResetTokens   PasswordResetToken[]
  twoFactor             UserTwoFactor?
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model UserTwoFactor {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret             String
  enabled            Boolean  @default(false)
  recoveryHashesJson String   @default("[]")
  updatedAt          DateTime @updatedAt
}

model LoginAttempt {
  id        String   @id @default(cuid())
  emailNorm String
  ip        String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([emailNorm, createdAt])
}

model AccountLockout {
  emailNorm   String   @id
  lockedUntil DateTime
  updatedAt   DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AdminSnapshot {
  key       String   @id
  dataJson  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String
  actorRole  String
  action     String
  targetJson String?
  metaJson   String?
  severity   String   @default("info")
  category   String   @default("admin")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

model Setting {
  key       String   @id
  valueJson String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  roleGrants  RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

// ──────────────────────────────────────────────
// كتالوج المتعلّم (Subjects → Courses → Chapters → Lessons)
// يتوافق مع `catalog-content.ts` وملفات generated/*.json
// ──────────────────────────────────────────────

model Subject {
  id          String   @id
  name        String
  slug        String
  icon        String   @default("BookOpen")
  color       String   @default("#1E3A5F")
  stagesJson  String   @default("[]")
  description String   @default("")
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0)
  courses     Course[]
  certificates Certificate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model Course {
  id             String    @id
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  offeringId     String?
  title          String
  description    String    @default("")
  stage          String
  grade          String
  secondaryTrack String?
  academicYear   String?
  term           Int?
  season         Int?
  instructor     String    @default("")
  thumbnail      String?
  duration       Int       @default(0)
  lessonsCount   Int       @default(0)
  studentsCount  Int       @default(0)
  rating         Float     @default(0)
  published      Boolean   @default(true)
  chapters       Chapter[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([subjectId])
}

model Chapter {
  id          String   @id
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  order       Int
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

model Lesson {
  id              String   @id
  chapterId       String
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  sourceLessonKey String?
  title           String
  description     String   @default("")
  duration        Int      @default(0)
  type            String   @default("video")
  videoUrl        String?
  content         String   @default("")
  keyPointsJson   String?
  order           Int
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progressRows LessonProgress[]

  @@index([chapterId])
}

/// تقدّم الطالب في درس (U5)
model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  /// `in_progress` | `completed`
  status         String    @default("in_progress")
  watchedSeconds Int       @default(0)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

// ──────────────────────────────────────────────
// شهادات (U5)
// ──────────────────────────────────────────────

/// شهادة إنجاز — التحقق عبر توقيع HMAC على `metaJson.nonce`
model Certificate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quizId        String?
  quiz          Quiz?    @relation(fields: [quizId], references: [id], onDelete: SetNull)
  /// `subject_completion` | `quiz_pass`
  kind          String
  title         String
  hashSignature String
  issuedAt      DateTime @default(now())
  metaJson      Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([subjectId])
  @@index([quizId])
}

// ──────────────────────────────────────────────
// اختبارات ومحاولات (U1)
// ──────────────────────────────────────────────

model Quiz {
  id           String         @id
  title        String
  description  String         @default("")
  subjectId    String
  grade        String
  lessonId     String?
  duration     Int            @default(30)
  passingScore Int            @default(60)
  status       String         @default("published")
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  certificates Certificate[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([subjectId])
  @@index([lessonId])
}

model QuizQuestion {
  id       String               @id
  quizId   String
  quiz     Quiz                 @relation(fields: [quizId], references: [id], onDelete: Cascade)
  position Int
  type     String
  stem     String
  payload  Json?
  points   Int?                 @default(1)
  options  QuizQuestionOption[]

  @@index([quizId])
}

model QuizQuestionOption {
  id         String       @id
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String
  isCorrect  Boolean      @default(false)
  position   Int

  @@index([questionId])
}

model QuizAttempt {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId     String
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  score      Int?
  total      Int?
  percentage Int?
  passed     Boolean?
  metaJson   Json?
  createdAt  DateTime  @default(now())

  answers QuizAttemptAnswer[]

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
}

model QuizAttemptAnswer {
  id            String      @id @default(cuid())
  attemptId     String
  attempt       QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  answerPayload Json
  isCorrect     Boolean?
  pointsAwarded Int?

  @@index([attemptId])
  @@index([questionId])
}
