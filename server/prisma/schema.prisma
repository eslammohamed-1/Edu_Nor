generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  admin
  super_admin
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String
  role             Role     @default(student)
  banned           Boolean  @default(false)
  grade            String?
  phone            String?
  stage            String?
  secondaryTrack   String?
  permissionsJson  String? // JSON array of strings for admin role
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AdminSnapshot {
  key       String   @id
  dataJson  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String
  actorRole  String
  action     String
  targetJson String?
  metaJson   String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

// ──────────────────────────────────────────────
// المنهج الدراسي: Stage → Grade → Term → Subject → Lesson → Section
// كل ID عبارة عن 12 رقم عشوائي غير مكرر
// ──────────────────────────────────────────────

model Stage {
  id     String  @id          // 12 رقم عشوائي
  name   String               // ابتدائي / إعدادي / ثانوي
  slug   String  @unique      // primary / prep / secondary
  order  Int
  grades Grade[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grade {
  id       String  @id
  stageId  String
  stage    Stage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name     String              // الصف الأول الابتدائي
  order    Int                 // 1-6 (ابتدائي) / 1-3 (إعدادي/ثانوي)
  terms    Term[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stageId])
}

model Term {
  id       String  @id
  gradeId  String
  grade    Grade   @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  name     String              // الترم الأول / الترم الثاني
  order    Int                 // 1 أو 2
  track    String?             // scientific_ar / scientific_languages / literary (ثانوي فقط)
  subjects Subject[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gradeId])
}

model Subject {
  id       String  @id
  termId   String
  term     Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  name     String              // اللغة العربية
  slug     String              // arabic
  icon     String  @default("BookOpen")
  color    String  @default("#1E3A5F")
  order    Int
  lessons  Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([termId])
}

model Lesson {
  id          String   @id
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  duration    Int      @default(0)
  type        String   @default("video")
  videoUrl    String?
  content     String   @default("")
  order       Int
  unitTitle   String?                        // اسم الوحدة (Section Group)
  sessionType String   @default("Regular")   // Regular / Revision
  sections    Section[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subjectId])
}

model Section {
  id           String  @id
  lessonId     String
  lesson       Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  type         String  @default("Regular")   // Regular / Revision / Exercise / Quiz
  content      String  @default("")
  duration     Int     @default(0)
  order        Int
  hasQuiz      Boolean @default(false)
  hasWorksheet Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([lessonId])
}

