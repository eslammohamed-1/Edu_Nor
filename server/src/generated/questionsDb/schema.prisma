generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/questionsDb"
}

datasource db {
  provider = "sqlite"
  url      = env("QUESTIONS_DATABASE_URL")
}

/// بنك الأسئلة: صف واحد لكل سؤال (المعرّف = id داخل الحمولة JSON).
model QuestionBankEntry {
  id          String   @id
  slug        String?
  payloadJson String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("question_bank")
}
