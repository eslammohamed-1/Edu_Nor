# =============================================================================
# EduNor — server/.env نموذج تطوير محلي (LOCAL)
# =============================================================================
# الفكرة: كل القيم هنا مثال للتشغيل على جهازك. لما تربط إنتاج أو خدمات سحابية
# (Postgres مستضاف، S3/R2، …) استبدل الـ DATABASE_URL والـ S3_* وغيرها فقط.
# انسخ الملف:  cp .env.example .env
# =============================================================================

# ─── قاعدة البيانات (محلي: Postgres على الجهاز أو Homebrew) ───
# استبدلها بـ Neon / Supabase / RDS عند النشر:
#   postgresql://USER:PASS@HOST:5432/DB?sslmode=require
DATABASE_URL="postgresql://edunor:edunor@localhost:5432/edunor"

# ─── JWT والجلسات ───
JWT_SECRET="dev-only-change-to-long-random-string-in-production"
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_DAYS=7
COOKIE_SECURE=false
PORT=3001

# ─── CORS (واجهة Vite محلية) ───
# في الإنتاج: ضع نطاق الواجهة الحقيقي بدل localhost
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── سوبر أدمن أولي (بعد db:seed) — غيّر في الإنتاج ───
SUPER_ADMIN_EMAIL=superadmin@edunor.local
SUPER_ADMIN_PASSWORD=EduNorSuper2026!

# ─── توثيق OpenAPI (Swagger) — محلي: تشغيله مفيد للتجربة ───
# إنتاج: غالباً false إلا لو وثائقك محمية
ENABLE_API_DOCS=true

# ─── بنك الأسئلة من القرص (افتراضي مسار المستودع) ───
# QUESTION_BANK_ROOT=data/question-bank

# ─── CSV (مثلاً تصدير المتعلمين) — اختياري ───
# CSV_DATA_DIR=

# ─── تخزين ملفات S3-compatible — محلي = MinIO (بورت 9000) ───
# لو مش شغّال MinIO/دوكر، سيب المتغيرات أو علّقها؛ الرفع من الكود يطلب الإعداد عند الاستخدام.
# إنتاج: استبدل بـ AWS S3 أو Cloudflare R2 أو أي S3 endpoint، مثال:
#   S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
#   S3_BUCKET=your-bucket
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=edunor
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ─── أمان الواجهة / كلمات المرور (U2) ───
# رابط الواجهة العام لروابط إعادة التعيين في البريد (إن وُجد مزود)
APP_PUBLIC_URL=http://localhost:5173
# محلياً: تعطيل استدعاء Have I Been Pwned (k-anonymity) إن لزم
# SKIP_BREACH_CHECK=1
# Helmet CSP: مصادر connect-src إضافية مفصولة بفواصل (مثلاً analytics)
# CSP_EXTRA_CONNECT_SRC=
